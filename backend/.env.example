# Copy this file to .env and fill in your own values.
# Never commit the real .env file.

# MySQL database connection
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=123456789
DB_NAME=sagarfeeds_db
DB_PORT=3306

# Server port
PORT=5000

# Secret used to sign login tokens (JWT).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# URL of the running frontend (used to build eSewa redirect + password reset links)
FRONTEND_URL=http://localhost:5173

# --- eSewa payment gateway ---
# Use test for eSewa sandbox/UAT credentials.
# Use live only after eSewa gives you real merchant credentials.
# In live mode, customers can log in with their normal eSewa accounts.
ESEWA_ENV=test
ESEWA_MERCHANT_CODE=
ESEWA_SECRET_KEY=

# --- Outgoing email (for "forgot password" reset links) ---
# Leave unset during development — reset links will be printed to the server
# console (and returned in the API response) instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Sagar Feeds <no-reply@sagarfeeds.com.np>"
